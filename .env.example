# ── Shared ────────────────────────────────────────────────────────────────────
USERS_DB=/absolute/path/to/users.db
# DB_ENCRYPTION_KEY=                       # optional: enables SQLCipher per-user DBs

# ── MCP Server (apps/mcp-server) ─────────────────────────────────────────────
MCP_BASE_URL=https://envel.dev/mcp
INTROSPECT_URL=http://127.0.0.1:9004/introspect
PORT=8001
# TEST_TOKEN=any-value                     # dev only: enables TestTokenVerifier
# TEST_DB=./users/test.db                  # dev only: path to local SQLite

# ── Auth Server (apps/auth-server) ───────────────────────────────────────────
AS_BASE_URL=https://envel.dev/auth
AUTH_PORT=9004
PLATFORM_URL=https://platform.envel.dev   # where auth-server redirects after Google OAuth
PLATFORM_SERVICE_SECRET=change-to-a-long-random-string
# Google OAuth (register BOTH redirect URIs in Google Cloud Console):
#   https://envel.dev/auth/google/callback           (MCP flow)
#   https://envel.dev/auth/platform/google/callback  (platform signup/login flow)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Platform (apps/platform) ──────────────────────────────────────────────────
PLATFORM_PORT=8002
SESSION_SECRET=change-to-a-long-random-string
SESSION_COOKIE_DOMAIN=.envel.dev          # set to enable cross-subdomain sessions; leave blank in dev
SECURE_COOKIES=true                        # true in prod (HTTPS-only cookies)
FORCE_HTTPS=true                           # true in prod (redirects HTTP → HTTPS)
CORS_ORIGINS=https://platform.envel.dev   # comma-separated; default is http://localhost:5173
AUTH_SERVER_URL=https://envel.dev/auth    # for platform → auth-server service calls

# ── Chat Agent ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=google/gemini-2.5-flash   # default
# MCP_SERVER_URL=http://localhost:8001/mcp   # default
